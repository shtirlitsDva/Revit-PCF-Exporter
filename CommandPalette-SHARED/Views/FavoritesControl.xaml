<UserControl x:Class="Norsyn.CommandPalette.Views.FavoritesControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Norsyn.CommandPalette.ViewModels"
             xmlns:design="clr-namespace:Norsyn.CommandPalette.Design"
             xmlns:conv="clr-namespace:Norsyn.CommandPalette.Views"
             xmlns:sysctl="clr-namespace:System.Windows.Controls;assembly=PresentationFramework"
             mc:Ignorable="d"
             d:DataContext="{x:Static design:DesignData.Favorites}"
             d:DesignWidth="216" d:DesignHeight="260"
             FontFamily="Segoe UI" UseLayoutRounding="True">

    <UserControl.Resources>
        <sysctl:BooleanToVisibilityConverter x:Key="BoolToVis" />
        <conv:InverseBoolToVisibilityConverter x:Key="InvBoolToVis" />

        <SolidColorBrush x:Key="MiniBg"    Color="#2B2B2E" />
        <SolidColorBrush x:Key="MiniBd"    Color="#45454B" />
        <SolidColorBrush x:Key="BarBg"     Color="#333337" />
        <SolidColorBrush x:Key="Hairline"  Color="#26262A" />
        <SolidColorBrush x:Key="ItemHover" Color="#3F3F47" />
        <SolidColorBrush x:Key="Accent"    Color="#0E639C" />
        <SolidColorBrush x:Key="TextPri"   Color="#E8E8E8" />
        <SolidColorBrush x:Key="TextRow"   Color="#E2E2E2" />
        <SolidColorBrush x:Key="TextMuted" Color="#8A8A8A" />
        <SolidColorBrush x:Key="StarGold"  Color="#E2B93B" />

        <Style x:Key="MiniFlat" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource ItemHover}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border Background="{StaticResource MiniBg}" BorderBrush="{StaticResource MiniBd}" BorderThickness="1" CornerRadius="6">
        <DockPanel LastChildFill="True">
            <!-- Header -->
            <Border DockPanel.Dock="Top" Background="{StaticResource BarBg}"
                    BorderBrush="{StaticResource Hairline}" BorderThickness="0,0,0,1" Padding="9,6">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="★" FontSize="12" Foreground="{StaticResource StarGold}" VerticalAlignment="Center" />
                        <TextBlock Text="Favorites" FontSize="11" FontWeight="SemiBold" Margin="7,0,0,0"
                                   Foreground="{StaticResource TextPri}" VerticalAlignment="Center" />
                    </StackPanel>
                    <Button HorizontalAlignment="Right" VerticalAlignment="Center" Cursor="Hand"
                            Command="{Binding ToggleLabelsCommand}" ToolTip="Toggle labels">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd" CornerRadius="3" Padding="6,1"
                                        BorderBrush="{StaticResource MiniBd}" BorderThickness="1"
                                        Background="Transparent">
                                    <TextBlock x:Name="t" Text="Aa" FontSize="10" FontWeight="SemiBold"
                                               Foreground="#9A9A9A" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <DataTrigger Binding="{Binding LabelsOn}" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="{StaticResource Accent}" />
                                        <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource Accent}" />
                                        <Setter TargetName="t" Property="Foreground" Value="White" />
                                    </DataTrigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>

            <!-- Empty state -->
            <TextBlock DockPanel.Dock="Top" TextWrapping="Wrap" TextAlignment="Center" Margin="14,18"
                       FontSize="11" Foreground="{StaticResource TextMuted}"
                       Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVis}}"
                       Text="No favorites yet. Star commands in the palette to pin them here." />

            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <Grid>
                    <!-- Labels ON: dense list -->
                    <ItemsControl ItemsSource="{Binding Items}" Margin="4"
                                  Visibility="{Binding LabelsOn, Converter={StaticResource BoolToVis}}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:FavoriteItemViewModel}">
                                <Button Style="{StaticResource MiniFlat}" Command="{Binding RunCommand}"
                                        ToolTip="{Binding Tooltip}" Padding="6,4">
                                    <StackPanel Orientation="Horizontal">
                                        <Grid Width="22" Height="22" Margin="0,0,8,0">
                                            <Border CornerRadius="5" Background="{Binding CategoryBrush}"
                                                    Visibility="{Binding HasIcon, Converter={StaticResource InvBoolToVis}}">
                                                <TextBlock Text="{Binding Monogram}" Foreground="White" FontSize="9.5"
                                                           FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                            <Image Source="{Binding Icon}" Width="22" Height="22"
                                                   Visibility="{Binding HasIcon, Converter={StaticResource BoolToVis}}" />
                                        </Grid>
                                        <TextBlock Text="{Binding Label}" FontSize="11.5" Foreground="{StaticResource TextRow}"
                                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Labels OFF: icon strip -->
                    <ItemsControl ItemsSource="{Binding Items}" Margin="8"
                                  Visibility="{Binding LabelsOff, Converter={StaticResource BoolToVis}}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:FavoriteItemViewModel}">
                                <Button Style="{StaticResource MiniFlat}" Command="{Binding RunCommand}"
                                        ToolTip="{Binding Label}" Margin="2" Padding="3">
                                    <Grid Width="28" Height="28">
                                        <Border CornerRadius="7" Background="{Binding CategoryBrush}"
                                                Visibility="{Binding HasIcon, Converter={StaticResource InvBoolToVis}}">
                                            <TextBlock Text="{Binding Monogram}" Foreground="White" FontSize="11"
                                                       FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                        <Image Source="{Binding Icon}" Width="28" Height="28"
                                               Visibility="{Binding HasIcon, Converter={StaticResource BoolToVis}}" />
                                    </Grid>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </ScrollViewer>
        </DockPanel>
    </Border>
</UserControl>
