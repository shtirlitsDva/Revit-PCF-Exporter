<UserControl x:Class="Norsyn.CommandPalette.Views.FavoritesControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Norsyn.CommandPalette.ViewModels"
             xmlns:design="clr-namespace:Norsyn.CommandPalette.Design"
             xmlns:conv="clr-namespace:Norsyn.CommandPalette.Views"
             xmlns:sysctl="clr-namespace:System.Windows.Controls;assembly=PresentationFramework"
             mc:Ignorable="d"
             d:DataContext="{x:Static design:DesignData.Favorites}"
             d:DesignWidth="216" d:DesignHeight="260"
             FontFamily="Segoe UI" UseLayoutRounding="True">

    <!-- Colours come solely from the central Colors.xaml (see CommandPaletteControl
         for the rationale). No hard-coded hex here. -->
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/CommandPalette.Core;component/Themes/Colors.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <sysctl:BooleanToVisibilityConverter x:Key="BoolToVis" />
            <conv:InverseBoolToVisibilityConverter x:Key="InvBoolToVis" />

            <Style x:Key="MiniFlat" TargetType="Button">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="{TemplateBinding Background}"
                                    CornerRadius="3" Padding="{TemplateBinding Padding}">
                                <ContentPresenter VerticalAlignment="Center"
                                                  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="{StaticResource Brush.Bg.SurfaceHi}" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Border Background="{StaticResource Brush.Bg.Panel}" BorderBrush="{StaticResource Brush.Border}" BorderThickness="1" CornerRadius="6">
        <DockPanel LastChildFill="True">
            <!-- Header -->
            <Border DockPanel.Dock="Top" Background="{StaticResource Brush.Bg.Surface}"
                    BorderBrush="{StaticResource Brush.Hairline}" BorderThickness="0,0,0,1" Padding="9,6">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="★" FontSize="12" Foreground="{StaticResource Brush.Palette.Star}" VerticalAlignment="Center" />
                        <TextBlock Text="Favorites" FontSize="11" FontWeight="SemiBold" Margin="7,0,0,0"
                                   Foreground="{StaticResource Brush.Text.Primary}" VerticalAlignment="Center" />
                    </StackPanel>
                    <Button HorizontalAlignment="Right" VerticalAlignment="Center" Cursor="Hand"
                            Command="{Binding ToggleLabelsCommand}" ToolTip="Toggle labels">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd" CornerRadius="3" Padding="6,1"
                                        BorderBrush="{StaticResource Brush.Border}" BorderThickness="1"
                                        Background="Transparent">
                                    <TextBlock x:Name="t" Text="Aa" FontSize="10" FontWeight="SemiBold"
                                               Foreground="{StaticResource Brush.Text.Secondary}" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <DataTrigger Binding="{Binding LabelsOn}" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="{StaticResource Brush.Accent}" />
                                        <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource Brush.Accent}" />
                                        <Setter TargetName="t" Property="Foreground" Value="{StaticResource Brush.Accent.Fg}" />
                                    </DataTrigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>

            <!-- Empty state -->
            <TextBlock DockPanel.Dock="Top" TextWrapping="Wrap" TextAlignment="Center" Margin="14,18"
                       FontSize="11" Foreground="{StaticResource Brush.Text.Secondary}"
                       Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVis}}"
                       Text="No favorites yet. Star commands in the palette to pin them here." />

            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <Grid>
                    <!-- Labels ON: dense list -->
                    <ItemsControl ItemsSource="{Binding Items}" Margin="4" Background="Transparent"
                                  AllowDrop="True"
                                  PreviewMouseLeftButtonDown="OnItemsPreviewMouseLeftButtonDown"
                                  PreviewMouseMove="OnItemsPreviewMouseMove"
                                  DragOver="OnItemsDragOver" Drop="OnItemsDrop"
                                  Visibility="{Binding LabelsOn, Converter={StaticResource BoolToVis}}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:FavoriteItemViewModel}">
                                <Button Style="{StaticResource MiniFlat}" Command="{Binding RunCommand}"
                                        ToolTip="{Binding Tooltip}" Padding="6,4">
                                    <StackPanel Orientation="Horizontal">
                                        <Grid Width="22" Height="22" Margin="0,0,8,0">
                                            <Border CornerRadius="5" Background="{Binding CategoryBrush}"
                                                    Visibility="{Binding HasIcon, Converter={StaticResource InvBoolToVis}}">
                                                <TextBlock Text="{Binding Monogram}" Foreground="{StaticResource Brush.Accent.Fg}" FontSize="9.5"
                                                           FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                            <Image Source="{Binding Icon}" Width="22" Height="22"
                                                   Visibility="{Binding HasIcon, Converter={StaticResource BoolToVis}}" />
                                        </Grid>
                                        <TextBlock Text="{Binding Label}" FontSize="11.5" Foreground="{StaticResource Brush.Text.Primary}"
                                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Labels OFF: icon strip -->
                    <ItemsControl ItemsSource="{Binding Items}" Margin="8" Background="Transparent"
                                  AllowDrop="True"
                                  PreviewMouseLeftButtonDown="OnItemsPreviewMouseLeftButtonDown"
                                  PreviewMouseMove="OnItemsPreviewMouseMove"
                                  DragOver="OnItemsDragOver" Drop="OnItemsDrop"
                                  Visibility="{Binding LabelsOff, Converter={StaticResource BoolToVis}}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:FavoriteItemViewModel}">
                                <Button Style="{StaticResource MiniFlat}" Command="{Binding RunCommand}"
                                        ToolTip="{Binding Label}" Margin="2" Padding="3">
                                    <Grid Width="28" Height="28">
                                        <Border CornerRadius="7" Background="{Binding CategoryBrush}"
                                                Visibility="{Binding HasIcon, Converter={StaticResource InvBoolToVis}}">
                                            <TextBlock Text="{Binding Monogram}" Foreground="{StaticResource Brush.Accent.Fg}" FontSize="11"
                                                       FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                        <Image Source="{Binding Icon}" Width="28" Height="28"
                                               Visibility="{Binding HasIcon, Converter={StaticResource BoolToVis}}" />
                                    </Grid>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </ScrollViewer>
        </DockPanel>
    </Border>
</UserControl>
