<UserControl x:Class="Norsyn.CommandPalette.Views.CommandPaletteControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Norsyn.CommandPalette.ViewModels"
             xmlns:design="clr-namespace:Norsyn.CommandPalette.Design"
             xmlns:conv="clr-namespace:Norsyn.CommandPalette.Views"
             xmlns:sysctl="clr-namespace:System.Windows.Controls;assembly=PresentationFramework"
             mc:Ignorable="d"
             d:DataContext="{x:Static design:DesignData.Palette}"
             d:DesignWidth="300" d:DesignHeight="560"
             FontFamily="Segoe UI"
             TextOptions.TextFormattingMode="Display"
             UseLayoutRounding="True">

    <!--
        Colours: this control merges ONLY the central colour tokens (Colors.xaml)
        from revit-shared-utilities-shared — the single source of truth. There are
        NO hard-coded hex values here; every brush is a {StaticResource Brush.*}.
        The window control-styles (Theme.xaml) are deliberately NOT merged, so the
        palette keeps its own bespoke chrome (flat rows, segmented toggle, stars).
    -->
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/CommandPalette.Core;component/Themes/Colors.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <sysctl:BooleanToVisibilityConverter x:Key="BoolToVis" />
            <conv:InverseBoolToVisibilityConverter x:Key="InvBoolToVis" />

            <!-- Flat, chrome-less button used for rows, stars, headers, links -->
            <Style x:Key="FlatButton" TargetType="Button">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="{TemplateBinding Background}"
                                    Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True">
                                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="{StaticResource Brush.Bg.SurfaceHi}" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Segmented view-toggle button. Active state (bold white text) is
                 applied per-instance via the BasedOn styles below. -->
            <Style x:Key="SegButton" TargetType="Button">
                <Setter Property="Foreground" Value="{StaticResource Brush.Text.Secondary}" />
                <Setter Property="FontSize" Value="11" />
                <Setter Property="FontWeight" Value="Medium" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" CornerRadius="3" Background="Transparent" Padding="0,4">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="{StaticResource Brush.Bg.SurfaceHi}" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="SegButton.Category" TargetType="Button" BasedOn="{StaticResource SegButton}">
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsCategoryView}" Value="True">
                        <Setter Property="Foreground" Value="{StaticResource Brush.Accent.Fg}" />
                        <Setter Property="FontWeight" Value="SemiBold" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
            <Style x:Key="SegButton.Source" TargetType="Button" BasedOn="{StaticResource SegButton}">
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsSourceView}" Value="True">
                        <Setter Property="Foreground" Value="{StaticResource Brush.Accent.Fg}" />
                        <Setter Property="FontWeight" Value="SemiBold" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
            <Style x:Key="SegButton.Az" TargetType="Button" BasedOn="{StaticResource SegButton}">
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsAzView}" Value="True">
                        <Setter Property="Foreground" Value="{StaticResource Brush.Accent.Fg}" />
                        <Setter Property="FontWeight" Value="SemiBold" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Border Background="{StaticResource Brush.Bg.Panel}" BorderBrush="{StaticResource Brush.Bg.Window}" BorderThickness="1,0,0,0">
        <DockPanel LastChildFill="True">

            <!-- Title bar -->
            <Border DockPanel.Dock="Top" Height="32" Background="{StaticResource Brush.Bg.Surface}"
                    BorderBrush="{StaticResource Brush.Hairline}" BorderThickness="0,0,0,1">
                <Grid Margin="10,0">
                    <TextBlock Text="Norsyn Commands" VerticalAlignment="Center"
                               FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource Brush.Text.Primary}" />
                    <Button HorizontalAlignment="Right" VerticalAlignment="Center"
                            Command="{Binding ToggleFavoritesCommand}"
                            Cursor="Hand" ToolTip="Open the favorites pane">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd" Background="{StaticResource Brush.Accent}" CornerRadius="3" Padding="9,3">
                                    <ContentPresenter />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="{StaticResource Brush.Accent.Hover}" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <TextBlock Text="★ Favorites" FontSize="11" Foreground="{StaticResource Brush.Accent.Fg}" />
                    </Button>
                </Grid>
            </Border>

            <!-- Toolbar -->
            <Border DockPanel.Dock="Top" Background="{StaticResource Brush.Bg.Surface}"
                    BorderBrush="{StaticResource Brush.Hairline}" BorderThickness="0,0,0,1" Padding="8">
                <StackPanel>
                    <!-- Search box -->
                    <Border Background="{StaticResource Brush.Bg.SurfaceLo}" BorderBrush="{StaticResource Brush.Border}"
                            BorderThickness="1" CornerRadius="3" Padding="8,5">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Path Grid.Column="0" Width="13" Height="13" Margin="0,0,7,0"
                                  Stretch="Uniform" Stroke="{StaticResource Brush.Text.Secondary}" StrokeThickness="2.4" Fill="Transparent"
                                  Data="M 6 1 A 5 5 0 1 0 6 11 A 5 5 0 1 0 6 1 M 10 10 L 14 14" />
                            <Grid Grid.Column="1">
                                <TextBox x:Name="SearchBox" Background="Transparent" BorderThickness="0"
                                         Foreground="{StaticResource Brush.Text.Primary}" FontSize="12"
                                         VerticalContentAlignment="Center" CaretBrush="{StaticResource Brush.Text.Primary}"
                                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Text="Search commands…" Foreground="{StaticResource Brush.Text.Disabled}" FontSize="12"
                                           IsHitTestVisible="False" VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Text.Length, ElementName=SearchBox}" Value="0">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- View segmented control -->
                    <Border Background="{StaticResource Brush.Bg.SurfaceLo}" CornerRadius="4" Padding="2" Margin="0,7,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="3" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="3" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Style="{StaticResource SegButton.Category}" Content="Category"
                                    Command="{Binding SetCategoryViewCommand}" />
                            <Button Grid.Column="2" Style="{StaticResource SegButton.Source}" Content="Source"
                                    Command="{Binding SetSourceViewCommand}" />
                            <Button Grid.Column="4" Style="{StaticResource SegButton.Az}" Content="A–Z"
                                    Command="{Binding SetAzViewCommand}" />

                            <!-- active-state overlays -->
                            <Border Grid.Column="0" Background="{StaticResource Brush.Accent}" CornerRadius="3" Panel.ZIndex="-1"
                                    Visibility="{Binding IsCategoryView, Converter={StaticResource BoolToVis}}" />
                            <Border Grid.Column="2" Background="{StaticResource Brush.Accent}" CornerRadius="3" Panel.ZIndex="-1"
                                    Visibility="{Binding IsSourceView, Converter={StaticResource BoolToVis}}" />
                            <Border Grid.Column="4" Background="{StaticResource Brush.Accent}" CornerRadius="3" Panel.ZIndex="-1"
                                    Visibility="{Binding IsAzView, Converter={StaticResource BoolToVis}}" />
                        </Grid>
                    </Border>

                    <!-- Utility row: count + expand/collapse (hidden while searching) -->
                    <Grid Margin="0,7,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontSize="10.5" Foreground="{StaticResource Brush.Text.Secondary}">
                                <Run Text="{Binding VisibleCount, Mode=OneWay}" /><Run Text=" commands" />
                            </TextBlock>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                    Visibility="{Binding IsSearching, Converter={StaticResource InvBoolToVis}}">
                            <Button Style="{StaticResource FlatButton}" Command="{Binding ExpandAllCommand}"
                                    Foreground="{StaticResource Brush.Accent.Hover}" HorizontalContentAlignment="Right">
                                <TextBlock Text="Expand all" FontSize="10.5" Foreground="{StaticResource Brush.Accent.Hover}" />
                            </Button>
                            <TextBlock Text=" · " FontSize="10.5" Foreground="{StaticResource Brush.Text.Secondary}" VerticalAlignment="Center" />
                            <Button Style="{StaticResource FlatButton}" Command="{Binding CollapseAllCommand}"
                                    HorizontalContentAlignment="Right">
                                <TextBlock Text="Collapse all" FontSize="10.5" Foreground="{StaticResource Brush.Accent.Hover}" />
                            </Button>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Command list -->
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding Groups}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:CategoryGroupViewModel}">
                            <StackPanel>
                                <!-- Group header -->
                                <Button Style="{StaticResource FlatButton}" Command="{Binding ToggleCommand}"
                                        Visibility="{Binding HasHeader, Converter={StaticResource BoolToVis}}">
                                    <Border Background="{StaticResource Brush.Bg.Surface}" Padding="9,6"
                                            BorderBrush="{StaticResource Brush.Hairline}" BorderThickness="0,0,0,1">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Width="12" FontSize="9" Foreground="{StaticResource Brush.Text.Secondary}"
                                                       VerticalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="▾" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsExpanded}" Value="False">
                                                                <Setter Property="Text" Value="▸" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <Border Width="8" Height="8" CornerRadius="2" Margin="0,0,7,0"
                                                    Background="{Binding Accent}" VerticalAlignment="Center" />
                                            <TextBlock Text="{Binding Header}" FontSize="11" FontWeight="SemiBold"
                                                       Foreground="{StaticResource Brush.Text.Primary}" VerticalAlignment="Center" />
                                            <TextBlock Text="{Binding Count}" FontSize="10" Margin="7,0,0,0"
                                                       Foreground="{StaticResource Brush.Text.Disabled}" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Border>
                                </Button>

                                <!-- Rows -->
                                <ItemsControl ItemsSource="{Binding Items}"
                                              Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVis}}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type vm:CommandItemViewModel}">
                                            <Button Style="{StaticResource FlatButton}" Command="{Binding RunCommand}"
                                                    ToolTip="{Binding Tooltip}">
                                                <Grid Margin="12,4,9,4">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>

                                                    <!-- Icon (PNG or monogram fallback) -->
                                                    <Grid Grid.Column="0" Width="22" Height="22" Margin="0,0,8,0">
                                                        <Border CornerRadius="5" Background="{Binding CategoryBrush}"
                                                                Visibility="{Binding HasIcon, Converter={StaticResource InvBoolToVis}}">
                                                            <TextBlock Text="{Binding Monogram}" Foreground="{StaticResource Brush.Accent.Fg}"
                                                                       FontSize="9.5" FontWeight="Bold"
                                                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                        </Border>
                                                        <Image Source="{Binding Icon}" Width="22" Height="22"
                                                               Visibility="{Binding HasIcon, Converter={StaticResource BoolToVis}}" />
                                                    </Grid>

                                                    <TextBlock Grid.Column="1" Text="{Binding Label}" FontSize="12"
                                                               Foreground="{StaticResource Brush.Text.Primary}" VerticalAlignment="Center"
                                                               TextTrimming="CharacterEllipsis" />

                                                    <TextBlock Grid.Column="2" Text="{Binding Source}" FontSize="10"
                                                               Foreground="{StaticResource Brush.Text.Disabled}" VerticalAlignment="Center"
                                                               Margin="8,0,6,0" />

                                                    <!-- Favorite star -->
                                                    <Button Grid.Column="3" Style="{StaticResource FlatButton}"
                                                            Command="{Binding ToggleFavoriteCommand}"
                                                            ToolTip="Toggle favorite" VerticalAlignment="Center">
                                                        <TextBlock FontSize="13" VerticalAlignment="Center">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Text" Value="☆" />
                                                                    <Setter Property="Foreground" Value="{StaticResource Brush.Text.Disabled}" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsFavorite}" Value="True">
                                                                            <Setter Property="Text" Value="★" />
                                                                            <Setter Property="Foreground" Value="{StaticResource Brush.Palette.Star}" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </Button>
                                                </Grid>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </DockPanel>
    </Border>
</UserControl>
