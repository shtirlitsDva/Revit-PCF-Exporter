<!--
    Norsyn central colour tokens  (Colors.xaml)
    ===========================================
    THE single source of truth for every colour used by any Norsyn Revit add-in
    surface — both the classic windows (via Theme.xaml's control styles) and the
    Command Palette dockable panes. If a colour is not here, it does not exist.

    HOW IT IS CONSUMED
      * Classic windows: ThemeManager loads this dictionary (embedded logical name
        "RevitShared.Colors.xaml") together with Theme.xaml at RUNTIME via
        XamlReader, because the legacy .NET Framework 4.8 Revit projects have no
        XAML/BAML compile step. Theme.xaml's styles reference these brushes with
        {DynamicResource}, so they resolve once both are merged into a window.
      * Command Palette (CommandPalette.Core, a modern UseWPF assembly): this same
        file is compiled in as a Page and merged via {StaticResource}. No control
        styles come along, so the palette keeps its own bespoke chrome while every
        colour value still lives here.

    PALETTE
      Cool blue-slate mimicking Revit's dark UI. The blue channel is kept highest
      in every surface tone so nothing drifts into flat neutral grey. The single
      interactive accent is a Revit blue; axis colours are the semantic X/Y/Z reds
      /greens/blues, desaturated so they read cleanly on a dark ground.

    NOTE
      This is a flat, brushes-only dictionary — no {StaticResource} cross-references
      between entries — so it loads standalone under XamlReader in any order.
-->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Surfaces: blue-slate, darkest -> lightest. B channel highest = never grey. -->
    <SolidColorBrush x:Key="Brush.Bg.Window"     Color="#20242B"/>
    <SolidColorBrush x:Key="Brush.Bg.Panel"      Color="#2A2F37"/>
    <SolidColorBrush x:Key="Brush.Bg.Surface"    Color="#333944"/>
    <SolidColorBrush x:Key="Brush.Bg.SurfaceHi"  Color="#3E4551"/>
    <SolidColorBrush x:Key="Brush.Bg.SurfaceLo"  Color="#191D23"/>

    <!-- Borders -->
    <SolidColorBrush x:Key="Brush.Border"        Color="#434B57"/>
    <SolidColorBrush x:Key="Brush.BorderHi"      Color="#586274"/>
    <!-- Subtle inner separator line, one step darker than a panel. -->
    <SolidColorBrush x:Key="Brush.Hairline"      Color="#22262D"/>

    <!-- Text -->
    <SolidColorBrush x:Key="Brush.Text.Primary"   Color="#E6EAF0"/>
    <SolidColorBrush x:Key="Brush.Text.Secondary" Color="#A6AFBD"/>
    <SolidColorBrush x:Key="Brush.Text.Disabled"  Color="#5F6874"/>

    <!-- Accent: Revit blue -->
    <SolidColorBrush x:Key="Brush.Accent"        Color="#4C8DD1"/>
    <SolidColorBrush x:Key="Brush.Accent.Hover"  Color="#5FA0E2"/>
    <SolidColorBrush x:Key="Brush.Accent.Press"  Color="#3A72AD"/>
    <SolidColorBrush x:Key="Brush.Accent.Fg"     Color="#FFFFFF"/>

    <!-- Semantic axis colours (desaturated for a dark ground) -->
    <SolidColorBrush x:Key="Brush.Axis.X"        Color="#E6746B"/>
    <SolidColorBrush x:Key="Brush.Axis.Y"        Color="#7FC08A"/>
    <SolidColorBrush x:Key="Brush.Axis.Z"        Color="#6FA0E0"/>

    <!-- Feedback -->
    <SolidColorBrush x:Key="Brush.Warn"          Color="#EF7A66"/>

    <!-- Command Palette accent: the favorite star. Warm gold reads as "pinned"
         against the cool slate without competing with the blue action accent. -->
    <SolidColorBrush x:Key="Brush.Palette.Star"  Color="#E2B93B"/>

</ResourceDictionary>
