<!--
    Norsyn central dark theme  (Theme.xaml)
    ========================================
    The control STYLES for every Norsyn Revit add-in window. All colour values
    live in the sibling Colors.xaml (the single source of truth); this file only
    describes how the standard controls look, referencing those colours by key.

    HOW IT IS CONSUMED
      This file is embedded (build action EmbeddedResource, stable LogicalName
      "RevitShared.Theme.xaml") into every add-in assembly and loaded at RUNTIME
      by ThemeManager via XamlReader, together with Colors.xaml. It is deliberately
      NOT a compiled <Page> ResourceDictionary: the shared code compiles into legacy
      .NET Framework 4.8 Revit projects that do not run the XAML/BAML build pipeline,
      so runtime loading is the only mechanism that works across all frameworks.

    WHY {DynamicResource} FOR COLOURS
      Because the brushes live in a SEPARATE dictionary (Colors.xaml) that
      ThemeManager merges alongside this one at apply time, the brush keys are not
      present while this file is parsed standalone by XamlReader. {DynamicResource}
      defers the lookup until both dictionaries are merged into the target window,
      so it resolves; {StaticResource} would throw at parse time. Structural
      resource references that ARE defined in this file may stay {StaticResource}.

    EXTENDING
      Add new implicit styles (ComboBox, CheckBox, ScrollBar, ...) here as windows
      adopt the theme. Add new colours to Colors.xaml, never here.
-->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============================ WINDOW ============================ -->

    <Style TargetType="{x:Type Window}">
        <Setter Property="Background" Value="{DynamicResource Brush.Bg.Window}"/>
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}"/>
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="FontSize"   Value="12"/>
    </Style>

    <!-- ============================ TEXTBLOCK ============================ -->

    <Style TargetType="{x:Type TextBlock}">
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}"/>
        <Setter Property="TextOptions.TextFormattingMode" Value="Ideal"/>
    </Style>

    <!-- ============================ TEXTBOX ============================ -->

    <Style TargetType="{x:Type TextBox}">
        <Setter Property="Foreground"        Value="{DynamicResource Brush.Text.Primary}"/>
        <Setter Property="Background"        Value="{DynamicResource Brush.Bg.Surface}"/>
        <Setter Property="BorderBrush"       Value="{DynamicResource Brush.Border}"/>
        <Setter Property="BorderThickness"   Value="1"/>
        <Setter Property="CaretBrush"        Value="{DynamicResource Brush.Accent.Hover}"/>
        <Setter Property="SelectionBrush"    Value="{DynamicResource Brush.Accent}"/>
        <Setter Property="SelectionOpacity"  Value="0.4"/>
        <Setter Property="Padding"           Value="4,3"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type TextBox}">
                    <Border x:Name="bd"
                            CornerRadius="3"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            SnapsToDevicePixels="True">
                        <ScrollViewer x:Name="PART_ContentHost"
                                      Margin="{TemplateBinding Padding}"
                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                      Focusable="False"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="BorderBrush" Value="{DynamicResource Brush.BorderHi}"/>
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="bd" Property="BorderBrush" Value="{DynamicResource Brush.Accent}"/>
                            <Setter TargetName="bd" Property="Background"  Value="{DynamicResource Brush.Bg.SurfaceHi}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Disabled}"/>
                            <Setter TargetName="bd" Property="Background" Value="{DynamicResource Brush.Bg.SurfaceLo}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================ BUTTON ============================ -->
    <!-- Default button is a filled primary action (accent). -->

    <Style TargetType="{x:Type Button}">
        <Setter Property="Foreground"      Value="{DynamicResource Brush.Accent.Fg}"/>
        <Setter Property="Background"      Value="{DynamicResource Brush.Accent}"/>
        <Setter Property="BorderBrush"     Value="{DynamicResource Brush.Accent.Press}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="FontWeight"      Value="SemiBold"/>
        <Setter Property="Padding"         Value="12,4"/>
        <Setter Property="Cursor"          Value="Hand"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border x:Name="bd"
                            CornerRadius="3"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Margin="{TemplateBinding Padding}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background"  Value="{DynamicResource Brush.Accent.Hover}"/>
                            <Setter TargetName="bd" Property="BorderBrush" Value="{DynamicResource Brush.Accent.Hover}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="bd" Property="Background"  Value="{DynamicResource Brush.Accent.Press}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="bd" Property="Background"  Value="{DynamicResource Brush.Bg.SurfaceHi}"/>
                            <Setter TargetName="bd" Property="BorderBrush" Value="{DynamicResource Brush.Border}"/>
                            <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Disabled}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================ GROUPBOX ============================ -->

    <Style TargetType="{x:Type GroupBox}">
        <Setter Property="Foreground"      Value="{DynamicResource Brush.Text.Secondary}"/>
        <Setter Property="Background"      Value="{DynamicResource Brush.Bg.Panel}"/>
        <Setter Property="BorderBrush"     Value="{DynamicResource Brush.Border}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding"         Value="8"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type GroupBox}">
                    <Border CornerRadius="5"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            SnapsToDevicePixels="True">
                        <DockPanel>
                            <Border DockPanel.Dock="Top"
                                    Background="{DynamicResource Brush.Bg.SurfaceLo}"
                                    CornerRadius="4,4,0,0"
                                    Padding="8,5">
                                <ContentPresenter ContentSource="Header"
                                                  TextBlock.Foreground="{DynamicResource Brush.Accent.Hover}"
                                                  TextBlock.FontWeight="SemiBold"/>
                            </Border>
                            <ContentPresenter Margin="{TemplateBinding Padding}"/>
                        </DockPanel>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
